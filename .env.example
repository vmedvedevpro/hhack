# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_MATCH_MODEL=claude-sonnet-4-6
ANTHROPIC_LETTER_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# Database. docker-compose ships a local postgres:16 on port 5432.
DATABASE_URL=postgresql+asyncpg://hhack:hhack@localhost:5432/hhack
# Override only if Alembic should connect to a different DB than the app
# (rare — leave blank otherwise).
ALEMBIC_DATABASE_URL=

# Browser profile. Persistent Chromium user-data directory; log in to
# HH by hand once inside this profile so the session cookie is kept.
BROWSER_PROFILE_DIR=./profile

# Optional overrides so the automated context matches the operator's
# real browser. Leave blank to use Playwright defaults — fine for the
# first `hhack-browser fingerprint` smoke test, but recommended to fill
# in before Phase 2 so HH does not see a UA/locale/timezone mismatch.
#
# To collect the values, open DevTools (F12) on any page in the browser
# you normally use HH from, switch to the Console tab, and run:
#
#   navigator.userAgent
#   navigator.language
#   Intl.DateTimeFormat().resolvedOptions().timeZone
#
# Copy each output (without the surrounding quotes) into the matching
# variable below.
BROWSER_USER_AGENT=
BROWSER_LOCALE=
BROWSER_TIMEZONE=

# Viewport size used when the automated context opens. Pick something
# plausible for the operator's monitor — Playwright's default (1280x720)
# is a common bot signature.
BROWSER_VIEWPORT_WIDTH=1440
BROWSER_VIEWPORT_HEIGHT=900

# Resume cache. `hhack-feed sync-resumes` reads applicant-zone resumes
# from HH and writes one `<hh_resume_id>.md` per resume here. The matcher
# then loads every .md from this directory. Leave blank to use the
# repo-relative default `./resumes/cache`.
RESUMES_CACHE_DIR=

# Match threshold. Jobs whose best per-resume score is below this are skipped.
MATCH_THRESHOLD=0.65

# Rate limits.
MAX_APPLICATIONS_PER_DAY=20
MIN_SECONDS_BETWEEN_ACTIONS=30
# Operator-local clock window during which the bot is allowed to act.
# Format: "HH:MM-HH:MM" in 24-hour time.
ACTIVE_HOURS_WINDOW=09:00-23:00

# Safety. Starts true. Flip to false once Phase 5 logic is validated.
DRY_RUN=true

# Logging.
LOG_LEVEL=INFO

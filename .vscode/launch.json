{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run feed worker",
      "type": "debugpy",
      "request": "launch",
      "module": "hhack.workers.feed",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Run chat worker",
      "type": "debugpy",
      "request": "launch",
      "module": "hhack.workers.chat",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Run Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "tests",
        "-v"
      ],
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Run Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": false,
      "console": "integratedTerminal"
    }
  ]
}
